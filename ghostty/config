# --- Font ---
theme = Black Metal
font-size = 16

# --- Window layout ---
window-padding-x = 14
window-padding-y = 14
#
# --- Titlebar / tabs (macOS) ---
# "tabs" integrates tabs into titlebar, "transparent" is also common
macos-titlebar-style = tabs

# --- Cursor ---
cursor-style = block
maximize = true

shell-integration-features = no-cursor

font-family = FiraCode Nerd Font
