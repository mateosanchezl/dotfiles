# --- Font ---
theme = TokyoNight Night
font-size = 16

# --- Window layout ---
window-padding-x = 14
window-padding-y = 14
#
# --- Titlebar / tabs (macOS) ---
# "tabs" integrates tabs into titlebar, "transparent" is also common
macos-titlebar-style = tabs

# --- Cursor ---
cursor-style = bar
maximize = true
